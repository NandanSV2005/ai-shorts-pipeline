# ==============================================================================
# FACELESS YOUTUBE AUTOMATION PIPELINE - CONFIGURATION
# ==============================================================================

# Core Niche & Settings
NICHE="Forgotten Inventions & Failed Tech of the 20th Century"

# AI/LLM Provider configuration (choices: gemini, openai)
LLM_PROVIDER="gemini"
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"

# Visual Assets API Configuration
PEXELS_API_KEY="your-pexels-api-key-here"
PIXABAY_API_KEY="your-pixabay-api-key-here"

# Text-To-Speech (TTS) Provider configuration (choices: edge-tts, openai, elevenlabs, piper)
TTS_PROVIDER="edge-tts"
# If using edge-tts: select voice code (e.g. en-US-GuyNeural, en-US-AriaNeural, en-GB-RyanNeural)
EDGE_TTS_VOICE="en-US-GuyNeural"
# Narration Speed Modulation (+50% / 1.50x for fast-paced viral Shorts)
TTS_RATE="+50%"
TTS_SPEED="1.50"
# If using ElevenLabs:
ELEVENLABS_API_KEY="your-elevenlabs-key"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
# If using Piper:
PIPER_MODEL_PATH="" # Path to your local .onnx voice model
PIPER_EXE_PATH=""   # Path to your piper.exe binary (if not on system PATH)

# Subtitle Generation Provider configuration (choices: local, openai)
WHISPER_PROVIDER="openai"

# Mock Pipeline for offline/no-key testing (choices: true, false)
MOCK_PIPELINE="false"

# Visual mode for video background (choices: gameplay, stock)
VISUAL_MODE="gameplay"
# Optional: Specific gameplay video filename under assets/gameplay/ (e.g. gameplay.mp4). If empty, picks one at random.
GAMEPLAY_VIDEO_FILE=""

# Custom path to your FFmpeg bin folder (e.g. C:\ffmpeg\bin) if not in IDE PATH
FFMPEG_DIR=""

# Notifications (choices: telegram, email, none)
NOTIFICATION_PROVIDER="none"
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
NOTIFY_EMAIL="recipient-email@gmail.com"
